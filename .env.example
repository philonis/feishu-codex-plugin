FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_BASE_URL=https://open.feishu.cn

# Optional defaults used by `enable` when flags are omitted.
FEISHU_BRIDGE_CHAT_ID=oc_xxx
CODEX_BRIDGE_SESSION_ID=last
CODEX_BRIDGE_CWD=/absolute/path/to/workspace

# Optional overrides.
CODEX_BRIDGE_CODEX_BIN=codex
CODEX_BRIDGE_MODEL=gpt-5.5
# Optional speed/quality override for Feishu-initiated turns.
# Leave empty to inherit the selected Codex session's reasoning effort.
# CODEX_BRIDGE_REASONING_EFFORT=medium
FEISHU_BRIDGE_WORKING_EMOJI=Typing
CODEX_HOME=/absolute/path/to/.codex

# By default the bridge removes OPENAI_BASE_URL/OPENAI_API_KEY inherited from
# Codex Desktop so nested `codex exec resume` uses the local ChatGPT login.
# Uncomment only if you intentionally want a custom API endpoint for the bridge.
# CODEX_BRIDGE_INHERIT_OPENAI_ENV=1
# CODEX_BRIDGE_OPENAI_BASE_URL=https://api.openai.com/v1
# CODEX_BRIDGE_OPENAI_API_KEY=sk-xxx
